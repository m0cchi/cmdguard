#include <tunables/global>

# AppArmor profile for cmdguard
#
# Deploy: /etc/apparmor.d/cmdguard
# Load:   apparmor_parser -r /etc/apparmor.d/cmdguard
#
# Kubernetes:
#   container.apparmor.security.beta.kubernetes.io/<container>: localhost/cmdguard-confined

# ============================================================
# cmdguard — the guard binary itself
# ============================================================
profile cmdguard /opt/cmdguard/cmdguard flags=(attach_disconnected) {
  include <abstractions/base>

  # Install dir (binary + policy file)
  /opt/cmdguard/**  r,

  # Tmpdir: symlinks, binary copy, policy copy, origbin copies
  /tmp/              rw,
  /tmp/cmdguard-*/** rwlk,

  # Read system binaries (for copying to origbin in namespace mode)
  /usr/**  r,
  /bin/*   r,
  /sbin/*  r,

  # Execute validated commands unconfined (policy already checked)
  /usr/bin/*                    Ux,
  /usr/local/bin/*              Ux,
  /bin/*                        Ux,
  /usr/sbin/*                   Ux,
  /sbin/*                       Ux,
  /tmp/cmdguard-*/origbin/*     Ux,

  # Launch confined process via .exec-target (namespace mode)
  /tmp/cmdguard-*/.exec-target  Px -> cmdguard-confined,

  /dev/tty   rw,
  /dev/pts/* rw,

  # Namespace mode (--namespace flag)
  capability sys_admin,
  mount options=(ro, bind) /tmp/cmdguard-*/bin/ -> /usr/bin/,
  mount options=(ro, bind) /tmp/cmdguard-*/bin/ -> /usr/local/bin/,
  mount options=(ro, bind) /tmp/cmdguard-*/bin/ -> /bin/,
  mount options=(ro, bind) /tmp/cmdguard-*/bin/ -> /usr/sbin/,
  mount options=(ro, bind) /tmp/cmdguard-*/bin/ -> /sbin/,
  mount options=(ro, bind) /tmp/cmdguard-*/bin/ -> /usr/local/sbin/,
  mount options=(rw, private) -> /,

  signal send set=(term kill),
  signal receive,
}

# ============================================================
# cmdguard-confined — child process launched by "cmdguard exec"
# ============================================================
profile cmdguard-confined flags=(attach_disconnected) {
  include <abstractions/base>
  include <abstractions/nameservice>

  /dev/tty    rw,
  /dev/pts/*  rw,

  /proc/self/**  r,
  /sys/kernel/mm/transparent_hugepage/** r,

  /etc/**          r,
  /usr/share/**    r,
  /opt/cmdguard/** r,

  @{HOME}/**  rwk,
  /tmp/**     rw,

  network,

  signal receive,
  signal send,

  # Execute ONLY through cmdguard (AppArmor resolves symlinks before matching)
  /opt/cmdguard/cmdguard            Px -> cmdguard,
  /tmp/cmdguard-*/bin/.cmdguard-bin Px -> cmdguard,
}
